---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href={import.meta.env.BASE_URL}>{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="right-side">
			<button id="theme-toggle" type="button" aria-label="Cambiar tema claro/oscuro">
				<svg id="icon-sun" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
					<path
						fill="currentColor"
						d="M12 4.5a1 1 0 0 1-1-1V2a1 1 0 1 1 2 0v1.5a1 1 0 0 1-1 1Zm0 15a1 1 0 0 1 1 1V22a1 1 0 1 1-2 0v-1.5a1 1 0 0 1 1-1ZM4.5 12a1 1 0 0 1-1 1H2a1 1 0 1 1 0-2h1.5a1 1 0 0 1 1 1Zm17.5-1h-1.5a1 1 0 1 0 0 2H22a1 1 0 1 0 0-2ZM6.34 7.76a1 1 0 0 1-1.42 0L3.87 6.7a1 1 0 1 1 1.42-1.42l1.05 1.06a1 1 0 0 1 0 1.42Zm12.02 10.5a1 1 0 0 1-1.41 0l-1.06-1.05a1 1 0 1 1 1.42-1.42l1.05 1.06a1 1 0 0 1 0 1.41ZM6.34 16.24a1 1 0 0 1 0 1.41l-1.05 1.06a1 1 0 1 1-1.42-1.42l1.06-1.05a1 1 0 0 1 1.41 0Zm12.02-10.5a1 1 0 0 1 0 1.42l-1.06 1.05a1 1 0 1 1-1.41-1.42l1.05-1.05a1 1 0 0 1 1.42 0ZM12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10Z"
					></path>
				</svg>
				<svg id="icon-moon" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
					<path
						fill="currentColor"
						d="M21.75 15.5A9.75 9.75 0 1 1 8.5 2.25a.75.75 0 0 1 .82 1.03A8.25 8.25 0 0 0 20.72 14.68a.75.75 0 0 1 1.03.82Z"
					></path>
				</svg>
			</button>
			<a class="social-link" href="https://github.com/ChertaPro" target="_blank">
				<span class="sr-only">Visitar mi GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="28" height="28"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<script>
	const toggleBtn = document.getElementById('theme-toggle');
	toggleBtn?.addEventListener('click', () => {
		const current = document.documentElement.getAttribute('data-theme');
		const next = current === 'dark' ? 'light' : 'dark';
		document.documentElement.setAttribute('data-theme', next);
		localStorage.setItem('theme', next);
	});
</script>

<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--bg);
		border-bottom: 1px solid rgb(var(--border));
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--text));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--text));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.right-side {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	.social-link {
		display: flex;
		color: rgb(var(--text));
	}
	#theme-toggle {
		background: none;
		border: 1px solid rgb(var(--border));
		border-radius: 6px;
		width: 36px;
		height: 36px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		color: rgb(var(--text));
	}
	#theme-toggle:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	#icon-moon {
		display: none;
	}
	:global([data-theme='dark']) #icon-sun {
		display: none;
	}
	:global([data-theme='dark']) #icon-moon {
		display: block;
	}
	@media (max-width: 720px) {
		.social-link {
			display: none;
		}
	}
</style>