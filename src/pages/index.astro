---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Datos livianos para el buscador (sin contenido completo, solo lo necesario)
const searchIndex = posts.map((post) => ({
	id: post.id,
	title: post.data.title,
	description: post.data.description,
}));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>A New Repo</h1>
				<p class="tagline">Proyectos, herramientas y la vida de un estudiante de Ciencias de la Computación.</p>
			</section>

			<div class="search-wrapper">
				<input
					type="text"
					id="search-input"
					placeholder="Buscar posts por título o tema..."
					aria-label="Buscar posts"
				/>
			</div>

			<p id="no-results" hidden>No se encontraron resultados.</p>

			<ul class="post-list" id="post-list">
				{
					posts.map((post) => (
						<li class="post-item" data-id={post.id}>
							<a href={`${base}/blog/${post.id}/`}>
								<h4 class="post-title">{post.data.title}</h4>
								<p class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
								<p class="post-description">{post.data.description}</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />

		<script define:vars={{ searchIndex }}>
			import('https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.mjs').then(({ default: Fuse }) => {
				const fuse = new Fuse(searchIndex, {
					keys: ['title', 'description'],
					threshold: 0.35,
				});

				const input = document.getElementById('search-input');
				const postList = document.getElementById('post-list');
				const noResults = document.getElementById('no-results');
				const items = Array.from(postList.querySelectorAll('.post-item'));

				input.addEventListener('input', (e) => {
					const query = e.target.value.trim();

					if (query === '') {
						items.forEach((item) => (item.hidden = false));
						noResults.hidden = true;
						return;
					}

					const results = fuse.search(query);
					const matchedIds = new Set(results.map((r) => r.item.id));

					let anyVisible = false;
					items.forEach((item) => {
						const isMatch = matchedIds.has(item.dataset.id);
						item.hidden = !isMatch;
						if (isMatch) anyVisible = true;
					});

					noResults.hidden = anyVisible;
				});
			});
		</script>

		<style>
			.hero {
				text-align: center;
				padding: 2em 1em 1em;
			}
			.hero h1 {
				font-size: 2.5em;
				margin-bottom: 0.3em;
			}
			.tagline {
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			.search-wrapper {
				max-width: 720px;
				margin: 1.5em auto;
				padding: 0 1em;
			}
			#search-input {
				width: 100%;
				padding: 0.7em 1em;
				font-size: 1em;
				border-radius: 8px;
				border: 1px solid rgb(var(--gray-light));
				box-sizing: border-box;
			}
			#no-results {
				text-align: center;
				color: rgb(var(--gray));
				margin: 2em 0;
			}
			.post-list {
				list-style: none;
				max-width: 720px;
				margin: 0 auto;
				padding: 0 1em;
			}
			.post-item {
				margin-bottom: 1.5em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.post-item a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			.post-title {
				margin: 0 0 0.2em;
				font-size: 1.3em;
			}
			.post-date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0 0 0.4em;
			}
			.post-description {
				margin: 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</body>
</html>